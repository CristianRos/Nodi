kebab-case -> invalid: TypeContainsInvalidGrapheme(0, "k")
Pascal_Case -> invalid: TypeContainsInvalidGrapheme(6, "_")
1Foo -> invalid: TypeContainsInvalidGrapheme(0, "1")
Foo Bar -> invalid: TypeContainsInvalidGrapheme(3, " ")
 -> invalid: TypeIsEmpty
