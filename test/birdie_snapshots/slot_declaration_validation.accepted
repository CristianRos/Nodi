snake_case -> valid
snake_case2 -> valid
_ -> invalid: ValueContainsInvalidGrapheme(0, "_")
_discard -> invalid: ValueContainsInvalidGrapheme(0, "_")
kebab-case -> invalid: ValueContainsInvalidGrapheme(5, "-")
PascalCase -> invalid: ValueContainsInvalidGrapheme(0, "P")
1foo -> invalid: ValueContainsInvalidGrapheme(0, "1")
foo bar -> invalid: ValueContainsInvalidGrapheme(3, " ")
foo@bar -> invalid: ValueContainsInvalidGrapheme(3, "@")
